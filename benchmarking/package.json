{
  "name": "adnauseam-benchmark",
  "version": "1.0.0",
  "description": "Puppeteer-based benchmarking system for AdNauseam browser extension",
  "type": "module",
  "scripts": {
    "build-ext": "cd .. && bash tools/make-chromium.sh",
    "benchmark": "node src/index.js",
    "benchmark:news": "node src/index.js --scenario news",
    "benchmark:mixed": "node src/index.js --scenario mixed",
    "benchmark:custom": "node src/index.js --scenario custom",
    "test-ext": "node test-extension.js"
  },
  "dependencies": {
    "ghost-cursor": "^1.3.0",
    "puppeteer-core": "^23.0.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "puppeteer-extra-plugin-user-data-dir": "^2.4.1"
  }
}
